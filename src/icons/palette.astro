  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  width="24"
  height="24"
>
  <ellipse
    cx="12"
    cy="12"
    rx="10"
    ry="9"
    fill="#F5D76E"
    stroke="#222"
