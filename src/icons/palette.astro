  <ellipse cx="8.5" cy="10" rx="1.2" ry="1.2" fill="#5BC0EB"></ellipse>
  <ellipse cx="15.5" cy="10" rx="1.2" ry="1.2" fill="#F25F5C"></ellipse>
  <ellipse cx="10" cy="15" rx="1.1" ry="1.1" fill="#70C1B3"></ellipse>
  <ellipse cx="14" cy="15" rx="1.1" ry="1.1" fill="#B2DBBF"></ellipse>
  <ellipse cx="12" cy="7.5" rx="1" ry="1" fill="#FFB400"></ellipse>
  <path
    d="M17 17c-1.5 2-6 2-7 0-.5-1 1-2 3.5-2s4 1 3.5 2z"
