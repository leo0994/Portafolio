<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>

<script is:inline>
  (function () {
    var CHARS =
      "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*";

    function randomText(length) {
      var result = "";
      for (var i = 0; i < length; i++) {
        result += CHARS[Math.floor(Math.random() * CHARS.length)];
      }
      return result;
    }

    function hackerEffect(element, finalText, duration, interval) {
      if (!element || !finalText) return;
      var frame = 0;
      var totalFrames = Math.floor(duration / interval);
      var textLength = finalText.length;

      function animate() {
        var progress = frame / totalFrames;
        var revealedCount = Math.floor(progress * textLength);
        var result = "";
        for (var i = 0; i < textLength; i++) {
          if (i < revealedCount) {
            result += finalText[i];
          } else {
            result += CHARS[Math.floor(Math.random() * CHARS.length)];
          }
        }
        element.textContent = result;
        frame++;
        if (frame <= totalFrames) {
          setTimeout(animate, interval);
        } else {
          element.textContent = finalText;
        }
      }
      animate();
    }

    function translate(key) {
      if (window.i18next && window.i18next.isInitialized) {
        var translated = window.i18next.t(key);
        if (translated && translated !== key) return translated;
      }
      return key;
    }

    function scrambleProjectsTexts() {
      var section = document.getElementById("proyectos");
      if (!section) return;

      // Título principal
      var titleSpan = document.getElementById("typed-projects-title");
      if (titleSpan) {
        var finalText = titleSpan.getAttribute("data-final") || "Mis Proyectos";
        var translated = translate("mis_proyectos");
        if (translated && translated !== "mis_proyectos")
          finalText = translated;

        titleSpan.setAttribute("data-final-text", finalText);
        titleSpan.textContent = randomText(finalText.length); // Mostrar texto aleatorio inicial
        titleSpan.classList.add("scrambled");
      }

      // Títulos de proyectos
      section.querySelectorAll("h3[data-i18n]").forEach(function (h3) {
        var key = h3.getAttribute("data-i18n");
        var value = translate(key) || key;
        h3.setAttribute("data-final-text", value);
        h3.textContent = randomText(value.length); // Mostrar texto aleatorio inicial
      });

      // Descripciones
      section.querySelectorAll("p[data-i18n]").forEach(function (p) {
        var key = p.getAttribute("data-i18n");
        var value = translate(key) || key;
        p.setAttribute("data-final-text", value);
        p.textContent = randomText(Math.min(value.length, 80)); // Mostrar texto aleatorio inicial
      });

      // Clientes
      section.querySelectorAll("span[data-client]").forEach(function (span) {
        var value = span.getAttribute("data-client");
        if (value) {
          span.setAttribute("data-final-text", value);
          span.textContent = randomText(value.length); // Mostrar texto aleatorio inicial
        }
      });

      // Tecnologías
      section.querySelectorAll("span[data-tech]").forEach(function (span) {
        var value = span.getAttribute("data-tech");
        if (value) {
          span.setAttribute("data-final-text", value);
          span.textContent = randomText(value.length); // Mostrar texto aleatorio inicial
        }
      });
    }

    function setupProjectsObserver() {
      var section = document.getElementById("proyectos");
      if (!section) return;

      var observer = new IntersectionObserver(
        function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting && !entry.target.dataset.hackerApplied) {
              entry.target.dataset.hackerApplied = "true";

              // Título principal
              var titleSpan = document.getElementById("typed-projects-title");
              if (titleSpan) {
                var finalText = titleSpan.getAttribute("data-final-text");
                if (finalText) {
                  hackerEffect(titleSpan, finalText, 800, 25);
                }
              }

              // Títulos
              section
                .querySelectorAll("h3[data-i18n]")
                .forEach(function (h3, index) {
                  var finalText = h3.getAttribute("data-final-text");
                  if (finalText) {
                    setTimeout(
                      function () {
                        hackerEffect(h3, finalText, 700, 25);
                      },
                      index * 100 + 200,
                    );
                  }
                });

              // Descripciones
              section
                .querySelectorAll("p[data-i18n]")
                .forEach(function (p, index) {
                  var finalText = p.getAttribute("data-final-text");
                  if (finalText) {
                    setTimeout(
                      function () {
                        hackerEffect(p, finalText, 1000, 15);
                      },
                      index * 100 + 400,
                    );
                  }
                });

              // Clientes
              section
                .querySelectorAll("span[data-client]")
                .forEach(function (span, index) {
                  var finalText = span.getAttribute("data-final-text");
                  if (finalText) {
                    setTimeout(
                      function () {
                        hackerEffect(span, finalText, 600, 20);
                      },
                      index * 80 + 300,
                    );
                  }
                });

              // Tecnologías
              section
                .querySelectorAll("span[data-tech]")
                .forEach(function (span, index) {
                  var finalText = span.getAttribute("data-final-text");
                  if (finalText) {
                    setTimeout(
                      function () {
                        hackerEffect(span, finalText, 500, 20);
                      },
                      index * 50 + 500,
                    );
                  }
                });
            }
          });
        },
        { threshold: 0.3 },
      );

      observer.observe(section);
    }

    function initProjects() {
      scrambleProjectsTexts();
      setupProjectsObserver();
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initProjects);
    } else {
      initProjects();
    }

    window.addEventListener("languageChanged", function () {
      var section = document.getElementById("proyectos");
      if (section) {
        section.removeAttribute("data-hacker-applied");
        scrambleProjectsTexts();
      }
    });
  })();
</script>

<script is:inline>
  // Drag to scroll functionality for carousel rows
  (function () {
    function setupDragScroll(carouselId) {
      var carousel = document.getElementById(carouselId);
      if (!carousel) return;

      var isDown = false;
      var startX;
      var scrollLeft;

      carousel.addEventListener("mousedown", function (e) {
        // Evitar drag en enlaces y botones
        if (
          e.target.closest("a") ||
          e.target.closest("button") ||
          e.target.tagName === "A" ||
          e.target.tagName === "BUTTON"
        ) {
          return;
        }

        isDown = true;
        carousel.setAttribute("data-dragging", "true");
        startX = e.pageX - carousel.offsetLeft;
        scrollLeft = carousel.scrollLeft;
        carousel.style.scrollBehavior = "auto";
      });

      carousel.addEventListener("mouseleave", function () {
        if (isDown) {
          isDown = false;
          carousel.setAttribute("data-dragging", "false");
          carousel.style.scrollBehavior = "smooth";
        }
      });

      carousel.addEventListener("mouseup", function () {
        if (isDown) {
          isDown = false;
          carousel.setAttribute("data-dragging", "false");
          carousel.style.scrollBehavior = "smooth";
        }
      });

      carousel.addEventListener("mousemove", function (e) {
        if (!isDown) return;
        e.preventDefault();
        var x = e.pageX - carousel.offsetLeft;
        var walk = (x - startX) * 2;
        carousel.scrollLeft = scrollLeft - walk;
      });

      // Prevenir click después de drag
      carousel.addEventListener(
        "click",
        function (e) {
          if (carousel.getAttribute("data-dragging") === "true") {
            e.preventDefault();
            e.stopPropagation();
          }
        },
        true,
      );
    }

    function initCarousels() {
      setupDragScroll("carousel-row-1");
      setupDragScroll("carousel-row-2");
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initCarousels);
    } else {
      initCarousels();
    }
  })();
</script>
