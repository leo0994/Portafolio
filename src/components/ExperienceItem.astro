---
interface Props {
  titleKey: string;
  descriptionKey: string;
  link?: string;
  dateKey: string;
}
const { dateKey, titleKey, link, descriptionKey } = Astro.props;
---

<div
  class="absolute w-3 h-3 bg-[rgb(240,240,240)] rounded-full mt-1.5 -start-1.5 border border-white"
>
</div>
<div class="mb-1 flex items-center">
  <span
    id={`typed-exp-date-${dateKey}`}
    class="hacker-text px-2 py-0.5 rounded bg-[rgb(30,30,30)] text-xs font-bold text-[#2dbdff] tracking-widest shadow-md"
    data-final={dateKey}></span>
</div>
<h3 class="text-lg font-semibold text-[#2dbdff]">
  <span
    id={`typed-exp-title-${titleKey}`}
    class="hacker-text"
    data-final={titleKey}></span>
</h3>
<p
  class="hacker-text standard-body-text mb-4 text-base"
  data-i18n={descriptionKey}
  data-final={descriptionKey}
>
</p>
{
  link && (
    <a
      href={link}
      class="inline-flex items-center px-4 py-2 text-sm font-medium text-[rgb(240,240,240)] bg-[rgb(25,25,25)] border border-[rgb(220,220,220)] rounded-lg hover:bg-[rgb(50,50,50)] hover:text-[#2dbdff] focus:z-10 focus:ring-4 focus:outline-none focus:ring-[rgb(100,100,100)]"
    >
      Saber más...
      <svg
        class="w-3 h-3 ms-2 rtl:rotate-180"
        aria-hidden="true"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 14 10"
      >
        <path
          stroke="currentColor"
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M1 5h12m0 0L9 1m4 4L9 9"
        />
      </svg>
    </a>
  )
}
