---
import ExperienceItem from "./ExperienceItem.astro";

const EXPERIENCE = [
  {
    dateKey: "exp1_fecha",
    titleKey: "exp1_titulo",
    descriptionKey: "exp1_descripcion",
  },
  {
    dateKey: "exp2_fecha",
    titleKey: "exp2_titulo",
    descriptionKey: "exp2_descripcion",
  },
  {
    dateKey: "exp3_fecha",
    titleKey: "exp3_titulo",
    descriptionKey: "exp3_descripcion",
  },
  {
    dateKey: "exp4_fecha",
    titleKey: "exp4_titulo",
    descriptionKey: "exp4_descripcion",
  },
  {
    dateKey: "exp5_fecha",
    titleKey: "exp5_titulo",
    descriptionKey: "exp5_descripcion",
  },
];
---

<ol class="relative border-s border-gray-400 ml-3">
  {
    EXPERIENCE.map((experience) => (
      <li class="mb-10 ms-4">
        <ExperienceItem {...experience} />
      </li>
    ))
  }
</ol>

<script is:inline>
  (function () {
    const CHARS =
      "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*";

    function randomText(length) {
      return Array(length)
        .fill(0)
        .map(() => CHARS[Math.floor(Math.random() * CHARS.length)])
        .join("");
    }

    function randomTextFromTemplate(template) {
      return Array.from(template)
        .map((char) => {
          if (/\s/.test(char)) return char;
          return CHARS[Math.floor(Math.random() * CHARS.length)];
        })
        .join("");
    }

    function hackerEffect(element, finalText, duration = 1000, fps = 30) {
      if (!element || !finalText) return;

      const frameInterval = 1000 / fps;
      const totalFrames = Math.ceil(duration / frameInterval);
      let currentFrame = 0;

      function animate() {
        currentFrame++;
        const progress = currentFrame / totalFrames;
        const revealedCount = Math.floor(progress * finalText.length);
        let displayText = "";

        for (let i = 0; i < finalText.length; i++) {
          if (i < revealedCount) {
            displayText += finalText[i];
          } else if (/\s/.test(finalText[i])) {
            displayText += finalText[i];
          } else {
            displayText += CHARS[Math.floor(Math.random() * CHARS.length)];
          }
        }

        element.textContent = displayText;

        if (currentFrame < totalFrames) {
          setTimeout(animate, frameInterval);
        } else {
          // Asegurar que el texto final se muestre correctamente
          element.textContent = finalText;
        }
      }

      // Iniciar animación inmediatamente
      animate();
    }

    function waitForI18next(callback, maxAttempts = 50) {
      let attempts = 0;
      const check = () => {
        attempts++;
        if (window.i18next && window.i18next.isInitialized) {
          callback();
        } else if (attempts < maxAttempts) {
          setTimeout(check, 100);
        }
      };
      check();
    }

    function scrambleExperienceTexts() {
      if (!window.i18next || !window.i18next.isInitialized) return;

      // Scramble fechas
      document.querySelectorAll('[id^="typed-exp-date-"]').forEach((span) => {
        const key = span.getAttribute("data-final");
        if (key) {
          const value = window.i18next.t(key);
          if (value && value !== key) {
            span.textContent = randomText(value.length);
            span.classList.add("scrambled");
            span.setAttribute("data-final-text", value);
          }
        }
      });

      // Scramble títulos
      document.querySelectorAll('[id^="typed-exp-title-"]').forEach((span) => {
        const key = span.getAttribute("data-final");
        if (key) {
          const value = window.i18next.t(key);
          if (value && value !== key) {
            span.textContent = randomText(value.length);
            span.classList.add("scrambled");
            span.setAttribute("data-final-text", value);
          }
        }
      });

      // Scramble descripciones
      const section = document.getElementById("experiencia");
      if (section) {
        section.querySelectorAll("p.hacker-text[data-final]").forEach((p) => {
          const key = p.getAttribute("data-final");
          if (key) {
            const value = window.i18next.t(key);
            if (value && value !== key) {
              p.textContent = randomTextFromTemplate(value);
              p.classList.add("scrambled");
              p.setAttribute("data-final-text", value);
            }
          }
        });
      }
    }

    function setupExperienceObserver() {
      const section = document.getElementById("experiencia");
      if (!section) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !entry.target.dataset.hackerApplied) {
              entry.target.dataset.hackerApplied = "true";

              // Verificar que i18next esté disponible antes de aplicar efectos
              if (!window.i18next || !window.i18next.isInitialized) return;

              // Efecto en fechas
              document
                .querySelectorAll('[id^="typed-exp-date-"]')
                .forEach((span, index) => {
                  let finalText = span.getAttribute("data-final-text");

                  // Si no hay texto final guardado, intentar obtenerlo de nuevo
                  if (!finalText) {
                    const key = span.getAttribute("data-final");
                    if (key) {
                      const translated = window.i18next.t(key);
                      if (translated && translated !== key) {
                        finalText = translated;
                        span.setAttribute("data-final-text", finalText);
                      }
                    }
                  }

                  if (finalText && finalText.length > 0) {
                    setTimeout(() => {
                      hackerEffect(span, finalText, 620, 25);
                    }, index * 150);
                  }
                });

              // Efecto en títulos
              document
                .querySelectorAll('[id^="typed-exp-title-"]')
                .forEach((span, index) => {
                  let finalText = span.getAttribute("data-final-text");

                  // Si no hay texto final guardado, intentar obtenerlo de nuevo
                  if (!finalText) {
                    const key = span.getAttribute("data-final");
                    if (key) {
                      const translated = window.i18next.t(key);
                      if (translated && translated !== key) {
                        finalText = translated;
                        span.setAttribute("data-final-text", finalText);
                      }
                    }
                  }

                  if (finalText && finalText.length > 0) {
                    setTimeout(
                      () => {
                        hackerEffect(span, finalText, 780, 25);
                      },
                      index * 150 + 100,
                    );
                  }
                });

              // Efecto en descripciones
              section
                .querySelectorAll("p.hacker-text[data-final]")
                .forEach((p, index) => {
                  let finalText = p.getAttribute("data-final-text");

                  // Si no hay texto final guardado, intentar obtenerlo de nuevo
                  if (!finalText) {
                    const key = p.getAttribute("data-final");
                    if (key) {
                      const translated = window.i18next.t(key);
                      if (translated && translated !== key) {
                        finalText = translated;
                        p.setAttribute("data-final-text", finalText);
                      }
                    }
                  }

                  if (finalText && finalText.length > 0) {
                    setTimeout(
                      () => {
                        hackerEffect(p, finalText, 1300, 15);
                      },
                      index * 200 + 300,
                    );
                  }
                });
            }
          });
        },
        {
          threshold: 0.01,
          rootMargin: "0px 0px -25% 0px",
        },
      );

      observer.observe(section);
    }

    function init() {
      waitForI18next(() => {
        scrambleExperienceTexts();
        setupExperienceObserver();
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }

    window.addEventListener("languageChanged", () => {
      const section = document.getElementById("experiencia");
      if (section) section.removeAttribute("data-hacker-applied");
      scrambleExperienceTexts();
      setupExperienceObserver();
    });
  })();
</script>
