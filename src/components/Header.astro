<header>
  <div
    class="header-container flex justify-center py-6 w-full xl:w-[1120] items-center gap-8 md:gap-12 max-w-7xl mx-auto"
  >
    <!-- Logo en video tipo cápsula -->
    <div class="header-logo-container flex-shrink-0">
      <video autoplay loop muted playsinline>
        <source src="/Portafolio/videos/LogoFavorito1.mp4" type="video/mp4" />
        Tu navegador no soporta videos.
      </video>
    </div>

    <!-- Botón menú hamburguesa -->
    <button id="menu-toggle" class="menu-toggle">☰</button>

    <!-- Menú de navegación para escritorio -->
    <nav
      class="hidden md:flex gap-6 relative items-center ml-4"
      id="desktop-nav"
    >
      <a href="#inicio" class="nav-link" data-i18n="inicio">Inicio</a>
      <a href="#experiencia" class="nav-link" data-i18n="experiencia"
        >Experiencia</a
      >
      <a href="#proyectos" class="nav-link" data-i18n="proyectos">Proyectos</a>
      <a href="#contacto" class="nav-link" data-i18n="contacto">Contacto</a>

      <!-- Selector de temas minimalista -->
      <div class="relative group ml-2">
        <button
          id="theme-selector"
          class="w-9 h-9 rounded-full bg-white/10 border border-white/20 hover:bg-white/20 hover:border-white/30 hover:shadow-lg hover:shadow-pink-500/20 transition-all duration-300 flex items-center justify-center text-base"
          aria-label="Cambiar tema"
        >
          🎨
        </button>

        <!-- Menú desplegable minimalista -->
        <div
          class="absolute top-full right-0 mt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
        >
          <div
            class="bg-slate-900/95 backdrop-blur-md rounded-xl border border-pink-500/30 shadow-2xl shadow-pink-500/10 p-3 min-w-[160px]"
          >
            <button
              data-theme-btn="default"
              class="theme-option w-full text-left px-3 py-2 rounded-lg text-sm text-gray-200 hover:bg-pink-500/20 hover:text-pink-300 transition flex items-center gap-2"
            >
              <span
                class="w-2.5 h-2.5 rounded-full bg-pink-400 shadow-sm shadow-pink-400"
              ></span>Default
            </button>
            <button
              data-theme-btn="dracula"
              class="theme-option w-full text-left px-3 py-2 rounded-lg text-sm text-gray-200 hover:bg-purple-500/20 hover:text-purple-300 transition flex items-center gap-2"
            >
              <span
                class="w-2.5 h-2.5 rounded-full bg-purple-400 shadow-sm shadow-purple-400"
              ></span>Dracula
            </button>
            <button
              data-theme-btn="solarized"
              class="theme-option w-full text-left px-3 py-2 rounded-lg text-sm text-gray-200 hover:bg-cyan-500/20 hover:text-cyan-300 transition flex items-center gap-2"
            >
              <span
                class="w-2.5 h-2.5 rounded-full bg-cyan-400 shadow-sm shadow-cyan-400"
              ></span>Solarized
            </button>
            <button
              data-theme-btn="matrix"
              class="theme-option w-full text-left px-3 py-2 rounded-lg text-sm text-gray-200 hover:bg-green-500/20 hover:text-green-300 transition flex items-center gap-2"
            >
              <span
                class="w-2.5 h-2.5 rounded-full bg-green-400 shadow-sm shadow-green-400"
              ></span>Matrix
            </button>
            <button
              data-theme-btn="catppuccin"
              class="theme-option w-full text-left px-3 py-2 rounded-lg text-sm text-gray-200 hover:bg-pink-500/20 hover:text-pink-300 transition flex items-center gap-2"
            >
              <span
                class="w-2.5 h-2.5 rounded-full bg-pink-400 shadow-sm shadow-pink-400"
              ></span>Catppuccin
            </button>
            <button
              data-theme-btn="radial-slate"
              class="theme-option w-full text-left px-3 py-2 rounded-lg text-sm text-gray-200 hover:bg-slate-500/20 hover:text-slate-300 transition flex items-center gap-2"
            >
              <span
                class="w-2.5 h-2.5 rounded-full bg-slate-400 shadow-sm shadow-slate-400"
              ></span>Radial Slate
            </button>
          </div>
        </div>
      </div>

      <!-- Botón para cambiar idioma -->
      <button
        id="language-toggle"
        class="ml-2 px-3 py-1 text-white bg-white/10 border border-white/30 rounded-lg hover:bg-white/20 transition duration-300"
      >
        EN
      </button>
      <div class="underline"></div>
    </nav>

    <!-- Menú de navegación móvil -->
    <nav
      id="mobile-menu"
      class="hidden fixed top-0 right-0 h-screen w-64 bg-black/90 text-white flex-col p-6 transform translate-x-full transition-transform duration-300 ease-in-out z-50"
    >
      <button id="close-menu" class="self-end text-2xl">✖</button>
      <a href="#inicio" class="py-3 text-lg" data-i18n="inicio">Inicio</a>
      <a href="#proyectos" class="py-3 text-lg" data-i18n="proyectos"
        >Proyectos</a
      >
      <a href="#experiencia" class="py-3 text-lg" data-i18n="experiencia"
        >Experiencia</a
      >
      <a href="#contacto" class="py-3 text-lg" data-i18n="contacto">Contacto</a>

      <!-- Selector de temas móvil -->
      <div class="mt-4 pt-4 border-t border-white/20">
        <p class="text-xs text-gray-400 mb-2">Temas</p>
        <div class="space-y-1">
          <button
            data-theme-btn="default"
            class="theme-option w-full text-left px-3 py-2 rounded text-sm text-gray-300 hover:bg-blue-500/20 hover:text-blue-300 transition flex items-center gap-2"
          >
            <span class="w-2 h-2 rounded-full bg-blue-400"></span>Default
          </button>
          <button
            data-theme-btn="dracula"
            class="theme-option w-full text-left px-3 py-2 rounded text-sm text-gray-300 hover:bg-purple-500/20 hover:text-purple-300 transition flex items-center gap-2"
          >
            <span class="w-2 h-2 rounded-full bg-purple-400"></span>Dracula
          </button>
          <button
            data-theme-btn="solarized"
            class="theme-option w-full text-left px-3 py-2 rounded text-sm text-gray-300 hover:bg-cyan-500/20 hover:text-cyan-300 transition flex items-center gap-2"
          >
            <span class="w-2 h-2 rounded-full bg-cyan-400"></span>Solarized
          </button>
          <button
            data-theme-btn="matrix"
            class="theme-option w-full text-left px-3 py-2 rounded text-sm text-gray-300 hover:bg-green-500/20 hover:text-green-300 transition flex items-center gap-2"
          >
            <span class="w-2 h-2 rounded-full bg-green-400"></span>Matrix
          </button>
          <button
            data-theme-btn="catppuccin"
            class="theme-option w-full text-left px-3 py-2 rounded text-sm text-gray-300 hover:bg-pink-500/20 hover:text-pink-300 transition flex items-center gap-2"
          >
            <span class="w-2 h-2 rounded-full bg-pink-400"></span>Catppuccin
          </button>
          <button
            data-theme-btn="radial-slate"
            class="theme-option w-full text-left px-3 py-2 rounded text-sm text-gray-300 hover:bg-slate-500/20 hover:text-slate-300 transition flex items-center gap-2"
          >
            <span class="w-2 h-2 rounded-full bg-slate-400"></span>Radial Slate
          </button>
        </div>
      </div>

      <!-- Botón idioma móvil -->
      <button
        id="language-toggle-mobile"
        class="mt-6 px-3 py-1 text-white bg-white/10 border border-white/30 rounded-lg hover:bg-white/20 transition duration-300"
      >
        EN
      </button>
    </nav>
  </div>
</header>

<script type="module">
  import { hackerTextEffect } from "/src/js/hackerTextEffect.js";

  // Función para generar texto aleatorio
  function randomText(length) {
    const chars =
      "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()_+-=<>?/";
    return Array(length)
      .fill(0)
      .map(() => chars[Math.floor(Math.random() * chars.length)])
      .join("");
  }

  // Esperar a que i18next esté listo y aplicar efectos
  function waitForI18next(callback, maxAttempts = 50) {
    let attempts = 0;
    const check = () => {
      attempts++;
      if (window.i18next && window.i18next.isInitialized) {
        callback();
      } else if (attempts < maxAttempts) {
        setTimeout(check, 100);
      }
    };
    check();
  }

  // Inicializar textos con scrambled (solo links de navegación)
  function initHeaderScrambled() {
    const navLinks = document.querySelectorAll(
      ".nav-link[data-i18n], #desktop-nav a[data-i18n], #mobile-menu a[data-i18n]",
    );
    navLinks.forEach((el) => {
      const key = el.getAttribute("data-i18n");
      const finalText = window.i18next
        ? window.i18next.t(key)
        : el.textContent.trim();
      if (finalText && finalText.length > 0) {
        el.setAttribute("data-final-text", finalText);
        el.textContent = randomText(finalText.length);
      }
    });
  }

  // Aplicar efecto de revelación (solo links de navegación)
  function applyHeaderEffect() {
    const navLinks = document.querySelectorAll(
      ".nav-link[data-i18n], #desktop-nav a[data-i18n], #mobile-menu a[data-i18n]",
    );
    navLinks.forEach((el, index) => {
      const key = el.getAttribute("data-i18n");
      // Usar i18next global si está disponible
      const finalText = window.i18next
        ? window.i18next.t(key)
        : el.getAttribute("data-final-text");
      if (finalText && finalText.length > 0) {
        el.setAttribute("data-final-text", finalText);
        setTimeout(() => {
          hackerTextEffect(el, finalText, 800, 25);
        }, index * 100);
      }
    });
  }

  // Inicializar scrambled con textos por defecto primero
  const navLinks = document.querySelectorAll(
    ".nav-link[data-i18n], #desktop-nav a[data-i18n], #mobile-menu a[data-i18n]",
  );
  navLinks.forEach((el) => {
    const originalText = el.textContent.trim();
    if (originalText && originalText.length > 0) {
      el.setAttribute("data-final-text", originalText);
      el.textContent = randomText(originalText.length);
    }
  });

  // Esperar a i18next y aplicar efecto
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      waitForI18next(() => {
        setTimeout(applyHeaderEffect, 100);
      });
    });
  } else {
    waitForI18next(() => {
      setTimeout(applyHeaderEffect, 100);
    });
  }

  // Re-aplicar cuando cambie el idioma
  window.addEventListener("languageChanged", () => {
    if (!window.i18next) return;

    const navLinks = document.querySelectorAll(
      ".nav-link[data-i18n], #desktop-nav a[data-i18n], #mobile-menu a[data-i18n]",
    );
    navLinks.forEach((el, index) => {
      const key = el.getAttribute("data-i18n");
      const finalText = window.i18next.t(key);
      if (finalText && finalText.length > 0) {
        el.setAttribute("data-final-text", finalText);
        setTimeout(() => {
          hackerTextEffect(el, finalText, 600, 25);
        }, index * 50);
      }
    });
  });
</script>
