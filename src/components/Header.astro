---
const base = import.meta.env.BASE_URL;
---

<header>
  <div
    class="header-container flex justify-center py-6 w-full xl:w-[1120] items-center gap-8 md:gap-12 max-w-7xl mx-auto"
  >
    <!-- Logo en video tipo cápsula -->
    <div class="header-logo-container flex-shrink-0">
      <video autoplay loop muted playsinline>
        <source src={`${base}videos/LogoFavorito1.mp4`} type="video/mp4" />
        Tu navegador no soporta videos.
      </video>
    </div>

    <!-- Botón menú hamburguesa -->
    <button id="menu-toggle" class="menu-toggle md:hidden">
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
      <span class="hamburger-line"></span>
    </button>

    <!-- Menú de navegación para escritorio -->
    <nav
      class="hidden md:flex gap-6 relative items-center ml-4"
      id="desktop-nav"
    >
      <a href="#inicio" class="nav-link" data-i18n="inicio">Inicio</a>
      <a href="#experiencia" class="nav-link" data-i18n="experiencia"
        >Experiencia</a
      >
      <a href="#proyectos" class="nav-link" data-i18n="proyectos">Proyectos</a>
      <a href="#contacto" class="nav-link" data-i18n="contacto">Contacto</a>

      <!-- Selector de temas minimalista -->
      <div class="relative group ml-2">
        <button
          id="theme-selector"
          class="w-9 h-9 rounded-full bg-white/10 border border-white/20 hover:bg-white/20 hover:border-white/30 hover:shadow-lg hover:shadow-pink-500/20 transition-all duration-300 flex items-center justify-center text-base"
          aria-label="Cambiar tema"
        >
          🎨
        </button>

        <!-- Menú desplegable minimalista -->
        <div
          class="absolute top-full right-0 mt-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 z-50"
        >
          <div
            class="bg-slate-900/95 backdrop-blur-md rounded-xl border border-pink-500/30 shadow-2xl shadow-pink-500/10 p-3 min-w-[160px]"
          >
            <button
              data-theme-btn="default"
              class="theme-option w-full text-left px-3 py-2 rounded-lg text-sm text-gray-200 hover:bg-pink-500/20 hover:text-pink-300 transition flex items-center gap-2"
            >
              <span
                class="w-2.5 h-2.5 rounded-full bg-cyan-400 shadow-sm shadow-cyan-400"
              ></span><span data-i18n="theme_default">Default</span>
            </button>
            <button
              data-theme-btn="solarized"
              class="theme-option w-full text-left px-3 py-2 rounded-lg text-sm text-gray-200 hover:bg-cyan-500/20 hover:text-cyan-300 transition flex items-center gap-2"
            >
              <span
                class="w-2.5 h-2.5 rounded-full bg-green-400 shadow-sm shadow-green-400"
              ></span><span data-i18n="theme_green">Verde</span>
            </button>
            <button
              data-theme-btn="light"
              class="theme-option w-full text-left px-3 py-2 rounded-lg text-sm text-gray-200 hover:bg-blue-500/20 hover:text-blue-300 transition flex items-center gap-2"
            >
              <span
                class="w-2.5 h-2.5 rounded-full bg-blue-300 shadow-sm shadow-blue-300"
              ></span><span data-i18n="theme_light">Claro</span>
            </button>
            <button
              data-theme-btn="radial-slate"
              class="theme-option w-full text-left px-3 py-2 rounded-lg text-sm text-gray-200 hover:bg-slate-500/20 hover:text-slate-300 transition flex items-center gap-2"
            >
              <span
                class="w-2.5 h-2.5 rounded-full bg-slate-400 shadow-sm shadow-slate-400"
              ></span><span data-i18n="theme_dark">Oscuro</span>
            </button>
          </div>
        </div>
      </div>

      <!-- Botón para cambiar idioma -->
      <button
        id="language-toggle"
        class="ml-2 px-3 py-1 text-white bg-white/10 border border-white/30 rounded-lg hover:bg-white/20 transition duration-300"
      >
        EN
      </button>
      <div class="underline"></div>
    </nav>

    <!-- Overlay para cerrar menú móvil -->
    <div id="mobile-overlay" class="mobile-overlay"></div>

    <!-- Menú de navegación móvil -->
    <nav id="mobile-menu" class="mobile-menu">
      <div class="mobile-menu-header">
        <div class="mobile-menu-logo">
          <img
            src={`${base}icons/LogoPlasmaCeleste.png`}
            alt="Leo Barrantes Logo"
            class="mobile-logo-img animate-spin-slow hover:scale-110 transition duration-300"
          />
          <h3 class="text-lg font-bold text-white">Menú</h3>
        </div>
        <button id="close-menu" class="close-menu-btn" aria-label="Cerrar menú">
          <span class="close-icon">✕</span>
        </button>
      </div>

      <div class="mobile-menu-content">
        <div class="mobile-menu-links">
          <a href="#inicio" class="mobile-nav-link" data-i18n="inicio">
            <span class="nav-icon">🏠</span>
            <span class="nav-text">Inicio</span>
            <span class="nav-arrow">→</span>
          </a>
          <a
            href="#experiencia"
            class="mobile-nav-link"
            data-i18n="experiencia"
          >
            <span class="nav-icon">💼</span>
            <span class="nav-text">Experiencia</span>
            <span class="nav-arrow">→</span>
          </a>
          <a href="#proyectos" class="mobile-nav-link" data-i18n="proyectos">
            <span class="nav-icon">🚀</span>
            <span class="nav-text">Proyectos</span>
            <span class="nav-arrow">→</span>
          </a>
          <a href="#contacto" class="mobile-nav-link" data-i18n="contacto">
            <span class="nav-icon">📧</span>
            <span class="nav-text">Contacto</span>
            <span class="nav-arrow">→</span>
          </a>
        </div>

        <!-- Selector de temas móvil -->
        <div class="mobile-themes-section">
          <p class="mobile-section-title">🎨 Temas</p>
          <div class="mobile-themes-list">
            <button data-theme-btn="default" class="mobile-theme-option">
              <span class="theme-dot" style="background: #00d9ff;"></span>
              <span data-i18n="theme_default" class="theme-label">Default</span>
            </button>
            <button data-theme-btn="light" class="mobile-theme-option">
              <span class="theme-dot" style="background: #3b82f6;"></span>
              <span data-i18n="theme_light" class="theme-label">Claro</span>
            </button>
            <button data-theme-btn="solarized" class="mobile-theme-option">
              <span class="theme-dot" style="background: #2aa198;"></span>
              <span data-i18n="theme_green" class="theme-label">Verde</span>
            </button>
            <button data-theme-btn="radial-slate" class="mobile-theme-option">
              <span class="theme-dot" style="background: #60a5fa;"></span>
              <span data-i18n="theme_dark" class="theme-label">Oscuro</span>
            </button>
          </div>
        </div>

        <!-- Botón idioma móvil -->
        <div class="mobile-language-section">
          <p class="mobile-section-title">🌐 Idioma</p>
          <button id="language-toggle-mobile" class="mobile-language-btn">
            <span class="text-lg font-bold">ES / EN</span>
          </button>
        </div>
      </div>
    </nav>
  </div>
</header>

<script type="module">
  import { hackerTextEffect } from "/src/js/hackerTextEffect.js";

  // Función para generar texto aleatorio
  function randomText(length) {
    const chars =
      "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()_+-=<>?/";
    return Array(length)
      .fill(0)
      .map(() => chars[Math.floor(Math.random() * chars.length)])
      .join("");
  }

  // Esperar a que i18next esté listo y aplicar efectos
  function waitForI18next(callback, maxAttempts = 50) {
    let attempts = 0;
    const check = () => {
      attempts++;
      if (window.i18next && window.i18next.isInitialized) {
        callback();
      } else if (attempts < maxAttempts) {
        setTimeout(check, 100);
      }
    };
    check();
  }

  // Inicializar textos con scrambled (solo links de navegación)
  function initHeaderScrambled() {
    const navLinks = document.querySelectorAll(
      ".nav-link[data-i18n], #desktop-nav a[data-i18n], #mobile-menu a[data-i18n]",
    );
    navLinks.forEach((el) => {
      const key = el.getAttribute("data-i18n");
      const finalText = window.i18next
        ? window.i18next.t(key)
        : el.textContent.trim();
      if (finalText && finalText.length > 0) {
        el.setAttribute("data-final-text", finalText);
        el.textContent = randomText(finalText.length);
      }
    });
  }

  // Aplicar efecto de revelación (solo links de navegación)
  function applyHeaderEffect() {
    const navLinks = document.querySelectorAll(
      ".nav-link[data-i18n], #desktop-nav a[data-i18n], #mobile-menu a[data-i18n]",
    );
    navLinks.forEach((el, index) => {
      const key = el.getAttribute("data-i18n");
      // Usar i18next global si está disponible
      const finalText = window.i18next
        ? window.i18next.t(key)
        : el.getAttribute("data-final-text");
      if (finalText && finalText.length > 0) {
        el.setAttribute("data-final-text", finalText);
        setTimeout(() => {
          hackerTextEffect(el, finalText, 800, 25);
        }, index * 100);
      }
    });
  }

  // Inicializar scrambled con textos por defecto primero
  const navLinks = document.querySelectorAll(
    ".nav-link[data-i18n], #desktop-nav a[data-i18n], #mobile-menu a[data-i18n]",
  );
  navLinks.forEach((el) => {
    const originalText = el.textContent.trim();
    if (originalText && originalText.length > 0) {
      el.setAttribute("data-final-text", originalText);
      el.textContent = randomText(originalText.length);
    }
  });

  // Esperar a i18next y aplicar efecto
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", () => {
      waitForI18next(() => {
        setTimeout(applyHeaderEffect, 100);
      });
    });
  } else {
    waitForI18next(() => {
      setTimeout(applyHeaderEffect, 100);
    });
  }

  // Re-aplicar cuando cambie el idioma
  window.addEventListener("languageChanged", () => {
    if (!window.i18next) return;

    const navLinks = document.querySelectorAll(
      ".nav-link[data-i18n], #desktop-nav a[data-i18n], #mobile-menu a[data-i18n]",
    );
    navLinks.forEach((el, index) => {
      const key = el.getAttribute("data-i18n");
      const finalText = window.i18next.t(key);
      if (finalText && finalText.length > 0) {
        el.setAttribute("data-final-text", finalText);
        setTimeout(() => {
          hackerTextEffect(el, finalText, 600, 25);
        }, index * 50);
      }
    });
  });

  // ==================== MENÚ MÓVIL ====================
  const menuToggle = document.getElementById("menu-toggle");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileOverlay = document.getElementById("mobile-overlay");
  const closeMenu = document.getElementById("close-menu");
  const mobileLinks = document.querySelectorAll(".mobile-nav-link");

  // Función para abrir el menú
  function openMobileMenu() {
    menuToggle.classList.add("active");
    mobileMenu.classList.add("active");
    mobileOverlay.classList.add("active");
    document.body.style.overflow = "hidden"; // Prevenir scroll
  }

  // Función para cerrar el menú
  function closeMobileMenu() {
    menuToggle.classList.remove("active");
    mobileMenu.classList.remove("active");
    mobileOverlay.classList.remove("active");
    document.body.style.overflow = ""; // Restaurar scroll
  }

  // Event listeners
  if (menuToggle) {
    menuToggle.addEventListener("click", openMobileMenu);
  }

  if (closeMenu) {
    closeMenu.addEventListener("click", closeMobileMenu);
  }

  if (mobileOverlay) {
    mobileOverlay.addEventListener("click", closeMobileMenu);
  }

  // Cerrar menú al hacer clic en un enlace con scroll suave
  mobileLinks.forEach((link) => {
    link.addEventListener("click", (e) => {
      e.preventDefault();
      const targetId = link.getAttribute("href");
      const targetSection = document.querySelector(targetId);

      closeMobileMenu();

      // Scroll suave después de cerrar el menú
      setTimeout(() => {
        if (targetSection) {
          targetSection.scrollIntoView({
            behavior: "smooth",
            block: "start",
          });
        }
      }, 400);
    });
  });

  // Cerrar menú con tecla ESC
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && mobileMenu.classList.contains("active")) {
      closeMobileMenu();
    }
  });

  // Cerrar menú al cambiar a modo desktop (resize)
  let resizeTimer;
  window.addEventListener("resize", () => {
    // Debounce para evitar múltiples llamadas
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      // Si la ventana es mayor a 768px (modo desktop) y el menú está abierto, cerrarlo
      if (window.innerWidth > 768 && mobileMenu.classList.contains("active")) {
        closeMobileMenu();
      }
    }, 100);
  });
</script>
