---
import LinkedinInIcon from "../icons/linkedin.astro";
import GithubInIcon from "../icons/github.astro";
import FileCVico from "../icons/filecvico.astro";
import SocialPill from "./SocialPill.astro";
import SectionContainer from "./SectionContainer.astro";
---

<SectionContainer id="inicio" class="pt-64 pb-40">
  <div
    class="flex flex-col items-center justify-center gap-y-8 max-w-5xl mx-auto"
  >
    <!-- Bloque alineado -->
    <div class="w-full max-w-[700px] text-left">
      <h1
        class="text-3xl sm:text-4xl lg:text-5xl font-bold mb-2 whitespace-nowrap"
      >
        <span class="text-gray-300">Hola, Soy </span>
        <span
          id="name-text"
          class="bg-gradient-to-r from-blue-400 to-cyan-300 bg-clip-text text-transparent hacker-text"
          data-final="Leo Barrantes"
        >
        </span>
      </h1>

      <div class="flex items-center mt-2 min-h-[3.5rem]">
        <h2
          class="text-2xl sm:text-3xl lg:text-4xl font-semibold flex items-center gap-2"
        >
          <span class="text-gray-300 ml-2">Soy&nbsp;</span>
          <span id="typed-text" class="text-blue-400 invisible"></span>
        </h2>
      </div>

      <p
        id="description-text"
        class="text-gray-400 text-lg sm:text-xl leading-relaxed mt-4 text-left max-w-[700px] hacker-text"
        data-final="3+ years of experience. From San José, Costa Rica."
        data-i18n-key="descripcion_principal"
      >
      </p>
    </div>

    <!-- Social Buttons -->
    <div
      id="social-buttons"
      class="flex items-center justify-center gap-3 mt-4 flex-wrap"
    >
      <SocialPill href="https://www.linkedin.com/in/leo-barrantes-928aa122a">
        <LinkedinInIcon class="w-6 h-6" />
        <span class="social-text">LinkedIn</span>
      </SocialPill>

      <SocialPill href="https://github.com/leo0994">
        <GithubInIcon class="w-6 h-6" />
        <span class="social-text">Github</span>
      </SocialPill>

      <SocialPill
        href="/Portafolio/cv/leobarrantescv_english.pdf"
        target="_blank"
      >
        <FileCVico class="w-6 h-6" />
        <span class="social-text">English</span>
      </SocialPill>

      <SocialPill
        href="/Portafolio/cv/leobarrantescv_español.pdf"
        target="_blank"
      >
        <FileCVico class="w-6 h-6" />
        <span class="social-text">Spanish</span>
      </SocialPill>
    </div>
  </div>
</SectionContainer>

<!-- Script para efecto hacker en la sección inicio - se ejecuta inmediatamente -->
<script is:inline>
  (function () {
    // Función para generar texto aleatorio
    function randomText(length) {
      const chars =
        "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()_+-=<>?/";
      let result = "";
      for (let i = 0; i < length; i++) {
        result += chars[Math.floor(Math.random() * chars.length)];
      }
      return result;
    }

    // Efecto hacker
    function hackerEffect(element, finalText, duration, interval) {
      if (!element || !finalText) return;
      const chars =
        "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()_+-=<>?/";
      let frame = 0;
      const totalFrames = Math.floor(duration / interval);
      const textLength = finalText.length;

      function animate() {
        const progress = frame / totalFrames;
        const revealedCount = Math.floor(progress * textLength);
        let result = "";
        for (let i = 0; i < textLength; i++) {
          if (i < revealedCount) {
            result += finalText[i];
          } else {
            result += chars[Math.floor(Math.random() * chars.length)];
          }
        }
        element.textContent = result;
        frame++;
        if (frame <= totalFrames) {
          setTimeout(animate, interval);
        } else {
          element.textContent = finalText;
        }
      }
      animate();
    }

    // Scramble inmediato (antes del render visual)
    function scrambleImmediately() {
      // Nombre
      var nameText = document.getElementById("name-text");
      if (nameText) {
        var finalName = nameText.getAttribute("data-final") || "Leo Barrantes";
        nameText.textContent = randomText(finalName.length);
        nameText.classList.add("scrambled");
      }

      // Descripción
      var descText = document.getElementById("description-text");
      if (descText) {
        var finalDesc =
          descText.getAttribute("data-final") ||
          "3+ years of experience. From San José, Costa Rica.";
        descText.textContent = randomText(finalDesc.length);
        descText.classList.add("scrambled");
      }

      // Botones sociales
      var socialTexts = document.querySelectorAll(".social-text");
      socialTexts.forEach(function (span) {
        var originalText = span.textContent.trim();
        if (originalText && originalText.length > 0) {
          span.setAttribute("data-final", originalText);
          span.textContent = randomText(originalText.length);
        }
      });
    }

    // Aplicar revelación con efecto
    function applyRevealEffect() {
      // Nombre
      var nameText = document.getElementById("name-text");
      if (nameText) {
        var finalName = nameText.getAttribute("data-final") || "Leo Barrantes";
        setTimeout(function () {
          hackerEffect(nameText, finalName, 1200, 30);
        }, 200);
      }

      // Descripción - usar traducción si está disponible
      var descText = document.getElementById("description-text");
      if (descText) {
        var finalDesc = descText.getAttribute("data-final");
        var i18nKey = descText.getAttribute("data-i18n-key");

        setTimeout(function () {
          if (window.i18next && window.i18next.isInitialized && i18nKey) {
            var translated = window.i18next.t(i18nKey);
            if (translated && translated !== i18nKey) {
              finalDesc = translated;
            }
          }
          hackerEffect(descText, finalDesc, 1500, 20);
        }, 600);
      }

      // Botones sociales
      var socialTexts = document.querySelectorAll(".social-text");
      socialTexts.forEach(function (span, index) {
        var finalText = span.getAttribute("data-final");
        if (finalText) {
          setTimeout(
            function () {
              hackerEffect(span, finalText, 700, 25);
            },
            500 + index * 100,
          );
        }
      });
    }

    // Ejecutar scramble inmediatamente
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", function () {
        scrambleImmediately();
        applyRevealEffect();
      });
    } else {
      scrambleImmediately();
      applyRevealEffect();
    }

    // Re-ejecutar cuando cambie el idioma
    window.addEventListener("languageChanged", function () {
      var descText = document.getElementById("description-text");
      if (descText && window.i18next) {
        var i18nKey = descText.getAttribute("data-i18n-key");
        if (i18nKey) {
          var finalDesc = window.i18next.t(i18nKey);
          if (finalDesc && finalDesc !== i18nKey) {
            hackerEffect(descText, finalDesc, 800, 20);
          }
        }
      }
    });
  })();
</script>
