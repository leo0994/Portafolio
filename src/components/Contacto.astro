---
const base = import.meta.env.BASE_URL;
---

<section
  id="contacto"
  class="max-w-4xl mx-auto px-6 py-16 pb-64"
  style="scroll-margin-top: 100px;"
>
  <div class="flex justify-center items-center mb-8 gap-4">
    <img
      src={`${base}icons/logo-plasma-celeste.png`}
      alt="Logo animado"
      class="w-12 h-12 animate-spin-slow hover:scale-110 transition duration-300"
    />
    <h2 class="text-white text-3xl font-bold text-center">
      <span
        id="typewriter-contact-heading"
        class="hacker-text"
        data-final="form_titulo"></span>
    </h2>
    <script is:inline>
      (function () {
        const CHARS =
          "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*";

        function randomText(length) {
          return Array(length)
            .fill(0)
            .map(() => CHARS[Math.floor(Math.random() * CHARS.length)])
            .join("");
        }

        function typewriterEffect(element, text, speed = 50) {
          element.textContent = "";
          let i = 0;
          function type() {
            if (i < text.length) {
              element.textContent += text.charAt(i);
              i++;
              setTimeout(type, speed);
            }
          }
          type();
        }

        function hackerEffectPlaceholder(
          input,
          finalText,
          duration = 700,
          fps = 25,
        ) {
          const frameInterval = 1000 / fps;
          const totalFrames = Math.ceil(duration / frameInterval);
          let currentFrame = 0;

          function animate() {
            currentFrame++;
            const progress = currentFrame / totalFrames;
            const revealedCount = Math.floor(progress * finalText.length);
            let displayText = "";

            for (let i = 0; i < finalText.length; i++) {
              if (i < revealedCount) {
                displayText += finalText[i];
              } else {
                displayText += CHARS[Math.floor(Math.random() * CHARS.length)];
              }
            }

            input.setAttribute("placeholder", displayText);

            if (currentFrame < totalFrames) {
              setTimeout(animate, frameInterval);
            } else {
              input.setAttribute("placeholder", finalText);
            }
          }
          animate();
        }

        function waitForI18next(callback, maxAttempts = 50) {
          let attempts = 0;
          const check = () => {
            attempts++;
            if (window.i18next && window.i18next.isInitialized) {
              callback();
            } else if (attempts < maxAttempts) {
              setTimeout(check, 100);
            }
          };
          check();
        }

        function scrambleContactTexts() {
          if (!window.i18next) return;

          // Heading
          const heading = document.getElementById("typewriter-contact-heading");
          if (heading) {
            const key = heading.getAttribute("data-final");
            const text =
              window.i18next.t(key) ||
              "¡Trabajemos juntos, hagamos realidad tu proyecto!";
            heading.textContent = randomText(text.length);
            heading.classList.add("scrambled");
            heading.setAttribute("data-final-text", text);
          }

          // Placeholders
          const inputs = document.querySelectorAll(
            "#contact-form input[placeholder], #contact-form textarea[placeholder]",
          );
          inputs.forEach((input) => {
            const key = input.getAttribute("data-i18n");
            const finalText = key
              ? window.i18next.t(key)
              : input.getAttribute("placeholder");
            if (finalText) {
              input.setAttribute("placeholder", randomText(finalText.length));
              input.setAttribute("data-final-placeholder", finalText);
            }
          });
        }

        function setupContactObserver() {
          const section = document.getElementById("contacto");
          if (!section) return;

          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (
                  entry.isIntersecting &&
                  !entry.target.dataset.hackerApplied
                ) {
                  entry.target.dataset.hackerApplied = "true";

                  // Typewriter en heading
                  const heading = document.getElementById(
                    "typewriter-contact-heading",
                  );
                  if (heading) {
                    const finalText = heading.getAttribute("data-final-text");
                    if (finalText) {
                      heading.textContent = "";
                      typewriterEffect(heading, finalText, 25);
                    }
                  }

                  // Hacker en placeholders
                  const inputs = document.querySelectorAll(
                    "#contact-form input[placeholder], #contact-form textarea[placeholder]",
                  );
                  inputs.forEach((input, index) => {
                    const finalText = input.getAttribute(
                      "data-final-placeholder",
                    );
                    if (finalText) {
                      setTimeout(() => {
                        hackerEffectPlaceholder(input, finalText, 620, 25);
                      }, index * 100);
                    }
                  });
                }
              });
            },
            {
              threshold: 0.01,
              rootMargin: "0px 0px -25% 0px",
            },
          );

          observer.observe(section);
        }

        function init() {
          waitForI18next(() => {
            scrambleContactTexts();
            setupContactObserver();
          });
        }

        if (document.readyState === "loading") {
          document.addEventListener("DOMContentLoaded", init);
        } else {
          init();
        }

        window.addEventListener("languageChanged", () => {
          const section = document.getElementById("contacto");
          if (section) section.removeAttribute("data-hacker-applied");
          scrambleContactTexts();
          setupContactObserver();
        });
      })();
    </script>
  </div>

  <form
    action="https://formspree.io/f/xkgrndrq"
    method="POST"
    class="bg-transparent p-6 rounded-xl border border-white/10 shadow-md space-y-4"
    id="contact-form"
    onsubmit="return mostrarModalExito(event);"
  >
    <div class="flex flex-col md:flex-row gap-4">
      <input
        type="text"
        name="nombre"
        placeholder="Nombre"
        data-i18n="nombre"
        required
        class="w-full bg-white/5 placeholder-white/70 text-white px-4 py-2 rounded-lg border border-white/10 focus:outline-none focus:ring-2 focus:ring-white/30"
      />
      <input
        type="text"
        name="apellido"
        placeholder="Apellido"
        data-i18n="apellido"
        required
        class="w-full bg-white/5 placeholder-white/70 text-white px-4 py-2 rounded-lg border border-white/10 focus:outline-none focus:ring-2 focus:ring-white/30"
      />
    </div>
    <div class="flex flex-col md:flex-row gap-4">
      <input
        type="email"
        name="email"
        placeholder="Email"
        data-i18n="email"
        required
        class="w-full bg-white/5 placeholder-white/70 text-white px-4 py-2 rounded-lg border border-white/10 focus:outline-none focus:ring-2 focus:ring-white/30"
      />
      <input
        type="tel"
        name="telefono"
        placeholder="Teléfono"
        data-i18n="telefono"
        required
        class="w-full bg-white/5 placeholder-white/70 text-white px-4 py-2 rounded-lg border border-white/10 focus:outline-none focus:ring-2 focus:ring-white/30"
      />
    </div>
    <textarea
      name="mensaje"
      placeholder="Escribe tu mensaje aquí..."
      data-i18n="mensaje"
      required
      class="w-full bg-white/5 placeholder-white/70 text-white px-4 py-3 rounded-lg border border-white/10 focus:outline-none focus:ring-2 focus:ring-white/30"
      rows="4"></textarea>

    <div class="flex justify-center">
      <button
        type="submit"
        class="rounded-full border border-white/10 px-6 py-2 bg-white/10 text-white hover:bg-white/20 hover:scale-110 transition duration-300"
      >
        <span data-i18n="enviar">Enviar mensaje</span>
      </button>
    </div>
  </form>
  <div
    id="modal-exito"
    class="hidden fixed inset-0 bg-black/50 items-center justify-center z-50"
  >
    <div
      class="bg-white text-black rounded-lg p-6 shadow-xl text-center space-y-4"
    >
      <h2 class="text-2xl font-bold">¡Mensaje enviado!</h2>
      <p>Gracias por contactarme, te responderé pronto.</p>
      <button
        type="button"
        onclick="cerrarModal()"
        class="mt-4 px-4 py-2 bg-blue-600 text-white rounded hover:bg-blue-700"
      >
        Cerrar
      </button>
    </div>
  </div>

  <script>
    function mostrarModalExito(event: Event) {
      event.preventDefault();
      var modal = document.getElementById("modal-exito");
      if (modal) {
        modal.classList.remove("hidden");
      }
      return;
    }
    function cerrarModal() {
      var modal = document.getElementById("modal-exito");
      if (modal) {
        modal.classList.add("hidden");
      }
      var form = document.getElementById("contact-form");
      if (form && "reset" in form) {
        (form as HTMLFormElement).reset();
      }
    }
  </script>
</section>
