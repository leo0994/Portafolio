---
import LinkedinInIcon from "../icons/linkedin.astro";
import GithubInIcon from "../icons/github.astro";
import FileCVico from "../icons/filecvico.astro";
import SocialPill from "./SocialPill.astro";

const base = import.meta.env.BASE_URL;
---

<div
  class="flex flex-col items-center justify-center gap-y-8 max-w-5xl mx-auto"
>
  <!-- Bloque alineado -->
  <div class="w-full max-w-[700px] text-left">
    <h1 class="hero-title mb-2 whitespace-nowrap">
      <span
        class="standard-body-text"
        id="saludo-intro"
        data-i18n-key="saludo_intro"
        >Hola, soy
      </span>
      <span
        id="name-text"
        class="text-[var(--brand-blue)] hacker-text"
        data-final="Leo Barrantes"
      >
      </span>
    </h1>

    <div class="mt-2 min-h-[5.2rem] sm:min-h-[5.8rem]">
      <h2 class="hero-subtitle leading-tight">
        <span
          class="standard-body-text ml-2"
          id="soy-prefix"
          data-i18n-key="soy_prefix">Soy&nbsp;</span
        >
        <span
          id="typed-text"
          class="text-[var(--brand-blue)] invisible typed-home-text"></span>
      </h2>
    </div>

    <p
      id="description-text"
      class="hero-description standard-body-text leading-relaxed mt-4 text-left max-w-[700px] hacker-text"
      data-final=""
      data-i18n-key="descripcion_principal"
    >
    </p>
  </div>

  <!-- Social Buttons -->
  <div
    id="social-buttons"
    class="flex items-center justify-center gap-3 mt-4 flex-wrap"
  >
    <SocialPill href="https://www.linkedin.com/in/leo-barrantes-928aa122a">
      <LinkedinInIcon class="w-6 h-6" />
      <span class="social-text">LinkedIn</span>
    </SocialPill>

    <SocialPill href="https://github.com/leo0994">
      <GithubInIcon class="w-6 h-6" />
      <span class="social-text">Github</span>
    </SocialPill>

    <SocialPill href={`${base}cv/leo-cv-ingles.pdf`} target="_blank">
      <FileCVico class="w-6 h-6" />
      <span class="social-text">English</span>
    </SocialPill>

    <SocialPill href={`${base}cv/leo-cv-espanol.pdf`} target="_blank">
      <FileCVico class="w-6 h-6" />
      <span class="social-text">Spanish</span>
    </SocialPill>
  </div>
</div>

<style>
  .hero-title {
    font-family: "Inter", "Work Sans", "Onest", sans-serif;
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    line-height: 1.06;
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .hero-subtitle {
    font-family: "Inter", "Work Sans", "Onest", sans-serif;
    font-size: clamp(1.72rem, 3.8vw, 2.7rem);
    line-height: 1.1;
    font-weight: 400;
    letter-spacing: 0.008em;
  }

  .hero-description {
    font-size: clamp(1.06rem, 1.52vw, 1.2rem);
    font-weight: 300;
    letter-spacing: 0.004em;
    line-height: 1.45;
  }

  #saludo-intro,
  #soy-prefix {
    font-weight: 300;
    letter-spacing: 0.005em;
  }

  #name-text,
  #typed-text {
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .typed-home-text {
    display: inline;
    white-space: normal;
    word-break: normal;
    overflow-wrap: anywhere;
  }

  :global(.typed-cursor) {
    margin-left: 2px;
    vertical-align: baseline;
  }
</style>
